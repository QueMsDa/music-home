# Copia este archivo como .env.local y rellena los valores

# URL de tu app en Vercel (sin barra final)
NEXT_PUBLIC_APP_URL=https://tu-app.vercel.app

# Clave secreta — genera una con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_SECRET=cambia_esto_por_una_clave_secreta_larga

# La misma clave para el frontend (necesaria para enviar comandos)
NEXT_PUBLIC_API_SECRET=cambia_esto_por_una_clave_secreta_larga

# IP local de tu Google Home (la encuentras en la app Google Home > dispositivo > Ajustes > Información del dispositivo)
GOOGLE_HOME_IP=192.168.1.XX

# Vercel Blob — se rellena automáticamente al conectar Vercel Blob
BLOB_READ_WRITE_TOKEN=

# Vercel KV — se rellena automáticamente al conectar Vercel KV
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
